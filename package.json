{
  "name": "@toon-protocol/swarm",
  "version": "0.0.0",
  "description": "Capability-market miner — a daemon-shaped worker that connects an LLM (Claude first) to the TOON capability market: watches the market feed, solves sealed predicates, and submits reveals (toon-meta#84).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "swarm": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "deployments",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "test": "node --import tsx --test test/*.test.ts",
    "swarm": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "toon",
    "capability-market",
    "risc-zero",
    "miner",
    "parimutuel",
    "predicate",
    "zkvm"
  ],
  "dependencies": {
    "viem": "^2.21.0"
  },
  "optionalDependencies": {
    "@toon-protocol/client": "^0.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
