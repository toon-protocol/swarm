# Copy to .env (gitignored) to run the miner against the capability market.
#
# READ-ONLY commands (`swarm status`, `swarm watch`, `swarm dry-run`) need only
# the RPC. Writing (staking, committing, revealing) needs a funded key and the
# explicit `--submit` flag — v0 never spends by default.

# Devnet EVM RPC (anvil, chainId 31337). Defaults baked into deployments/devnet.json.
SWARM_RPC_URL=https://evm-rpc.devnet.toonprotocol.dev

# Which market to mine: "real" (Groth16 verifier) or "mock" (dev-mode seals).
SWARM_MARKET=mock

# Miner key. ONLY required for paid writes (commit/reveal/stake). Fund via:
#   curl -X POST https://faucet.devnet.toonprotocol.dev/api/request \
#     -H 'content-type: application/json' -d '{"address":"0xYOURADDR"}'
# SWARM_MINER_KEY=0x...
